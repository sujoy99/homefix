NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

ENABLE_SEED=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@1234
DEFAULT_ADMIN_NID=1111111111
DEFAULT_ADMIN_MOBILE=00000000000

LOG_LEVEL=debug
LOG_DIR=logs
LOG_RETENTION_DAYS=3

JWT_ACCESS_SECRET=super-secret-access
JWT_REFRESH_SECRET=super-secret-refresh
JWT_ACCESS_EXPIRES_IN=5m
JWT_REFRESH_EXPIRES_IN=7d

DB_HOST=localhost
DB_PORT=5432
DB_NAME=homefix
DB_USER=homefix_db_user
DB_PASSWORD=homefix_db

# Push Notifications (FCM)
# FCM_SERVICE_ACCOUNT_JSON='{}' # Omit to use stub (no-op) provider

# VoIP / Calls (Jitsi)
# CALL_PROVIDER=jitsi                          # default; change to 'agora' for Phase 2
# JITSI_SERVER_URL=https://meet.jit.si         # default (dev). Production: your own Jitsi server URL
# JITSI_APP_ID=homefix                         # required for JWT auth on self-hosted Jitsi
# JITSI_APP_SECRET=your-jitsi-app-secret  