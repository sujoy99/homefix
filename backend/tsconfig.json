{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",
    "types": ["node"],

    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ],

    "sourceMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "paths": {
      "@config/*": ["./src/config/*"],
      "@utils": ["./src/utils/index.ts"],
      "@utils/*": ["./src/utils/*"],
      "@logger/*": ["./src/logger/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@routes/*": ["./src/routes/*"],
      "@services/*": ["./src/services/*"],
      "@errors/*": ["./src/errors/*"],
      "@http/*": ["./src/http/*"],
      "@modules/*": ["./src/modules/*"],
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
